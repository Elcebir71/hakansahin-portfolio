---
/**
 * Geographic coordinates (lat, lon) → percentage position
 * Using focused equirectangular projection:
 *   lon range: -15 to 125  |  lat range: -20 to 65
 *   x% = (lon + 15) / 140 * 100
 *   y% = (65 - lat) / 85 * 100
 */
const journey = [
  { id: 1, name: "Mongolia", city: "Ulaanbaatar", period: "1996–1997", lat: 47.92, lon: 106.91, image: "/images/countries/mongolia.png" },
  { id: 2, name: "Turkmenistan", city: "Ashgabat", period: "1997–2000", lat: 37.95, lon: 58.38, image: "/images/countries/turkmenistan.png" },
  { id: 3, name: "Albania", city: "Tirana", period: "2000–2007", lat: 41.33, lon: 19.82, image: "/images/countries/albania.png" },
  { id: 4, name: "India", city: "New Delhi", period: "2007–2008", lat: 28.61, lon: 77.21, image: "/images/countries/india.png" },
  { id: 5, name: "Türkiye", city: "Hatay", period: "2008–2011", lat: 36.20, lon: 36.16, image: "/images/countries/turkey.png" },
  { id: 6, name: "Bosnia", city: "Sarajevo", period: "2011–2016", lat: 43.86, lon: 18.41, image: "/images/countries/bosnia.png" },
  { id: 7, name: "Tanzania", city: "Dar es Salaam", period: "2016–2021", lat: -6.79, lon: 39.28, image: "/images/countries/tanzania.png" },
  { id: 8, name: "Netherlands", city: "Nijkerk", period: "2025–Present", lat: 52.22, lon: 5.49, image: "/images/countries/netherlands.png" },
];

function toX(lon: number) { return ((lon + 15) / 140) * 100; }
function toY(lat: number) { return ((65 - lat) / 85) * 100; }

const points = journey.map(c => ({ ...c, x: toX(c.lon), y: toY(c.lat) }));
const svgPolyline = points.map(p => `${p.x},${p.y}`).join(" ");
---

<div class="relative w-full rounded-3xl overflow-hidden bg-slate-900 dark:bg-slate-900 border border-slate-800/50">
  <!-- SVG layer for lines -->
  <svg
    class="absolute inset-0 w-full h-full"
    viewBox="0 0 100 100"
    preserveAspectRatio="none"
    fill="none"
  >
    <!-- Subtle grid -->
    {[20, 40, 60, 80].map(v => (
      <line x1={v} y1="0" x2={v} y2="100" stroke="rgba(148,163,184,0.06)" stroke-width="0.15" />
    ))}
    {[20, 40, 60, 80].map(v => (
      <line x1="0" y1={v} x2="100" y2={v} stroke="rgba(148,163,184,0.06)" stroke-width="0.15" />
    ))}

    <!-- Journey path -->
    <polyline
      points={svgPolyline}
      stroke="rgba(245,158,11,0.35)"
      stroke-width="0.2"
      fill="none"
      stroke-linejoin="round"
    />

    <!-- Animated dash overlay -->
    <polyline
      points={svgPolyline}
      stroke="rgba(245,158,11,0.7)"
      stroke-width="0.15"
      fill="none"
      stroke-dasharray="1 2"
      stroke-linejoin="round"
      class="journey-dash"
    />

    <!-- Dot pulses at each point -->
    {points.map(p => (
      <circle cx={p.x} cy={p.y} r="0.6" fill="rgba(245,158,11,0.15)">
        <animate attributeName="r" values="0.6;1.2;0.6" dur="3s" repeatCount="indefinite" />
        <animate attributeName="opacity" values="0.3;0.1;0.3" dur="3s" repeatCount="indefinite" />
      </circle>
    ))}
  </svg>

  <!-- Country markers (HTML positioned over SVG) -->
  <div class="relative w-full" style="padding-bottom: 60%;">
    {points.map((country) => (
      <div
        class="absolute group z-10"
        style={`left: ${country.x}%; top: ${country.y}%; transform: translate(-50%, -50%);`}
      >
        <!-- Photo circle -->
        <div class="relative">
          <div class="w-10 h-10 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-full overflow-hidden border-2 border-amber-500/50 shadow-lg shadow-amber-500/10 transition-all duration-300 group-hover:scale-125 group-hover:border-amber-400 group-hover:shadow-amber-500/30 group-hover:z-20">
            <img
              src={country.image}
              alt={country.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- Step number -->
          <span class="absolute -top-1 -right-1 w-4 h-4 sm:w-5 sm:h-5 bg-amber-500 rounded-full flex items-center justify-center text-[8px] sm:text-[9px] font-bold text-white shadow-sm">
            {country.id}
          </span>
        </div>

        <!-- Tooltip -->
        <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 opacity-0 group-hover:opacity-100 transition-all duration-200 pointer-events-none z-30 whitespace-nowrap">
          <div class="bg-slate-800 text-white text-[10px] sm:text-xs px-3 py-2 rounded-xl shadow-xl border border-slate-700/50">
            <p class="font-semibold text-amber-400">{country.name}</p>
            <p class="text-slate-300">{country.city} · {country.period}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  @keyframes journey-dash-scroll {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -30; }
  }
  .journey-dash {
    animation: journey-dash-scroll 20s linear infinite;
  }
</style>
