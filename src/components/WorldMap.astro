---
const journey = [
  { id: 1, name: "Mongolia", city: "Ulaanbaatar", period: "1996–1997", lat: 47.92, lon: 106.91, image: "/images/countries/mongolia.png" },
  { id: 2, name: "Turkmenistan", city: "Ashgabat", period: "1997–2000", lat: 37.95, lon: 58.38, image: "/images/countries/turkmenistan.png" },
  { id: 3, name: "Albania", city: "Tirana", period: "2000–2007", lat: 41.33, lon: 19.82, image: "/images/countries/albania.png" },
  { id: 4, name: "India", city: "New Delhi", period: "2007–2008", lat: 28.61, lon: 77.21, image: "/images/countries/india.png" },
  { id: 5, name: "Türkiye", city: "Hatay", period: "2008–2011", lat: 36.20, lon: 36.16, image: "/images/countries/turkey.png" },
  { id: 6, name: "Bosnia", city: "Sarajevo", period: "2011–2016", lat: 43.86, lon: 18.41, image: "/images/countries/bosnia.png" },
  { id: 7, name: "Tanzania", city: "Dar es Salaam", period: "2016–2021", lat: -6.79, lon: 39.28, image: "/images/countries/tanzania.png" },
  { id: 8, name: "Netherlands", city: "Nijkerk", period: "2025–Present", lat: 52.22, lon: 5.49, image: "/images/countries/netherlands.png" },
];
---

<div class="relative w-full rounded-3xl overflow-hidden bg-slate-950 border border-slate-800/50" style="min-height: 500px;">
  <canvas id="globe-canvas" class="w-full" style="height: 500px; display: block;"></canvas>

  <!-- Country markers overlay -->
  <div id="globe-markers" class="absolute inset-0 pointer-events-none" style="height: 500px;">
    {journey.map((country) => (
      <button
        class="globe-marker pointer-events-auto absolute opacity-0 group"
        data-lat={country.lat}
        data-lon={country.lon}
        data-id={country.id}
        data-name={country.name}
        data-city={country.city}
        data-period={country.period}
        data-image={country.image}
        style="transform: translate(-50%, -50%);"
      >
        <div class="relative">
          <div class="w-7 h-7 sm:w-8 sm:h-8 rounded-full overflow-hidden border-2 border-amber-500/70 shadow-lg shadow-amber-500/20 transition-all duration-300 hover:scale-150 hover:border-amber-400 hover:shadow-amber-500/40 hover:z-20">
            <img
              src={country.image}
              alt={country.name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-amber-500 rounded-full flex items-center justify-center text-[7px] font-bold text-white shadow-sm">
            {country.id}
          </span>
        </div>
      </button>
    ))}
  </div>

  <!-- Country detail panel -->
  <div id="country-panel" class="absolute bottom-4 left-4 right-4 sm:left-auto sm:right-6 sm:bottom-6 sm:w-72 opacity-0 translate-y-4 transition-all duration-500 pointer-events-none z-20">
    <div class="bg-slate-900/90 backdrop-blur-xl rounded-2xl border border-slate-700/50 shadow-2xl overflow-hidden">
      <div id="panel-image" class="h-32 w-full overflow-hidden">
        <img src="" alt="" class="w-full h-full object-cover" />
      </div>
      <div class="p-4">
        <p id="panel-step" class="text-[10px] font-medium tracking-[0.2em] uppercase text-amber-400 mb-1"></p>
        <h3 id="panel-name" class="text-lg font-serif font-bold text-white"></h3>
        <p id="panel-city" class="text-sm text-slate-400 mt-0.5"></p>
        <p id="panel-period" class="text-xs text-slate-500 mt-1"></p>
      </div>
    </div>
  </div>

  <!-- Controls hint -->
  <div class="absolute top-4 left-4 flex items-center gap-2 text-[10px] text-slate-500 tracking-widest uppercase pointer-events-none">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.042 21.672L13.684 16.6m0 0l-2.51 2.225.569-9.47 5.227 7.917-3.286-.672zM12 2.25V4.5m5.834.166l-1.591 1.591M20.25 10.5H18M7.757 14.743l-1.59 1.59M6 10.5H3.75m4.007-4.243l-1.59-1.59" />
    </svg>
    <span>Drag to rotate · Click marker to explore</span>
  </div>
</div>

<script>
  import * as THREE from "three";
  import { OrbitControls } from "three/addons/controls/OrbitControls.js";
  import gsap from "gsap";

  const canvas = document.getElementById("globe-canvas") as HTMLCanvasElement;
  if (!canvas) throw new Error("Globe canvas not found");

  const container = canvas.parentElement!;
  const markersContainer = document.getElementById("globe-markers")!;

  const width = () => container.clientWidth;
  const height = () => 500;

  // ─── Scene Setup ───
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, width() / height(), 0.1, 1000);
  camera.position.set(0, 0, 3.2);

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
  });
  renderer.setSize(width(), height());
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.2;

  // ─── Controls ───
  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping = true;
  controls.dampingFactor = 0.05;
  controls.enableZoom = false;
  controls.enablePan = false;
  controls.rotateSpeed = 0.5;
  controls.minPolarAngle = Math.PI * 0.2;
  controls.maxPolarAngle = Math.PI * 0.8;

  // ─── Textures ───
  const loader = new THREE.TextureLoader();
  const dayTexture = loader.load("/textures/earth-day.jpg");
  const nightTexture = loader.load("/textures/earth-night.jpg");
  const bumpTexture = loader.load("/textures/earth-bump.jpg");

  [dayTexture, nightTexture, bumpTexture].forEach((t) => {
    t.colorSpace = THREE.SRGBColorSpace;
  });

  // ─── Sun Direction ───
  function getSunDirection(): THREE.Vector3 {
    const now = new Date();
    const dayOfYear = Math.floor(
      (now.getTime() - new Date(now.getFullYear(), 0, 0).getTime()) / 86400000
    );
    const utcHours = now.getUTCHours() + now.getUTCMinutes() / 60;

    const declination = 23.45 * Math.sin(((2 * Math.PI) / 365) * (dayOfYear - 81));
    const decRad = (declination * Math.PI) / 180;
    const lonRad = (-(utcHours / 24) * 360 + 180) * (Math.PI / 180);

    return new THREE.Vector3(
      Math.cos(decRad) * Math.cos(lonRad),
      Math.sin(decRad),
      Math.cos(decRad) * Math.sin(lonRad)
    ).normalize();
  }

  // ─── Day/Night Shader Material ───
  const earthMaterial = new THREE.ShaderMaterial({
    uniforms: {
      dayMap: { value: dayTexture },
      nightMap: { value: nightTexture },
      bumpMap: { value: bumpTexture },
      sunDirection: { value: getSunDirection() },
    },
    vertexShader: `
      varying vec2 vUv;
      varying vec3 vNormal;
      varying vec3 vPosition;

      void main() {
        vUv = uv;
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform sampler2D dayMap;
      uniform sampler2D nightMap;
      uniform vec3 sunDirection;

      varying vec2 vUv;
      varying vec3 vNormal;
      varying vec3 vPosition;

      void main() {
        vec3 normal = normalize(vNormal);
        float sunDot = dot(normal, sunDirection);

        vec4 dayColor = texture2D(dayMap, vUv);
        vec4 nightColor = texture2D(nightMap, vUv);

        // Smooth twilight transition
        float blend = smoothstep(-0.15, 0.2, sunDot);

        // Night lights glow with slight blue tint
        vec4 nightGlow = nightColor * vec4(1.0, 0.9, 0.7, 1.0) * 1.5;

        vec4 finalColor = mix(nightGlow, dayColor, blend);

        // Subtle atmosphere rim lighting
        vec3 viewDir = normalize(cameraPosition - vPosition);
        float rim = 1.0 - max(dot(viewDir, normal), 0.0);
        rim = pow(rim, 4.0);
        vec3 atmosphereColor = mix(vec3(0.1, 0.4, 1.0), vec3(0.9, 0.6, 0.2), max(sunDot, 0.0));
        finalColor.rgb += atmosphereColor * rim * 0.4;

        gl_FragColor = finalColor;
      }
    `,
  });

  // ─── Globe ───
  const globeGeometry = new THREE.SphereGeometry(1, 64, 64);
  const globe = new THREE.Mesh(globeGeometry, earthMaterial);
  scene.add(globe);

  // ─── Atmosphere Glow ───
  const atmosphereGeometry = new THREE.SphereGeometry(1.015, 64, 64);
  const atmosphereMaterial = new THREE.ShaderMaterial({
    vertexShader: `
      varying vec3 vNormal;
      varying vec3 vPosition;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      varying vec3 vNormal;
      varying vec3 vPosition;
      void main() {
        vec3 viewDir = normalize(cameraPosition - vPosition);
        float intensity = pow(1.0 - dot(viewDir, vNormal), 2.5);
        gl_FragColor = vec4(0.3, 0.6, 1.0, intensity * 0.3);
      }
    `,
    transparent: true,
    side: THREE.BackSide,
    depthWrite: false,
  });
  const atmosphere = new THREE.Mesh(atmosphereGeometry, atmosphereMaterial);
  scene.add(atmosphere);

  // ─── Ambient Light ───
  scene.add(new THREE.AmbientLight(0x222244, 0.5));

  // ─── Journey Data ───
  const journeyData = Array.from(document.querySelectorAll(".globe-marker")).map((el) => {
    const e = el as HTMLElement;
    return {
      element: e,
      lat: parseFloat(e.dataset.lat!),
      lon: parseFloat(e.dataset.lon!),
      id: parseInt(e.dataset.id!),
      name: e.dataset.name!,
      city: e.dataset.city!,
      period: e.dataset.period!,
      image: e.dataset.image!,
    };
  });

  // ─── Journey Lines ───
  function latLonToVec3(lat: number, lon: number, radius: number): THREE.Vector3 {
    const phi = (90 - lat) * (Math.PI / 180);
    const theta = (lon + 180) * (Math.PI / 180);
    return new THREE.Vector3(
      -radius * Math.sin(phi) * Math.cos(theta),
      radius * Math.cos(phi),
      radius * Math.sin(phi) * Math.sin(theta)
    );
  }


  // ─── Marker Projection ───
  function projectToScreen(lat: number, lon: number): { x: number; y: number; visible: boolean } {
    const pos = latLonToVec3(lat, lon, 1.02);
    pos.applyMatrix4(globe.matrixWorld);

    const camDir = new THREE.Vector3();
    camera.getWorldDirection(camDir);
    const toPoint = pos.clone().sub(camera.position).normalize();
    const dot = camDir.dot(toPoint);

    const ndc = pos.clone().project(camera);
    const x = (ndc.x * 0.5 + 0.5) * width();
    const y = (-ndc.y * 0.5 + 0.5) * height();

    const globeCenter = new THREE.Vector3(0, 0, 0).applyMatrix4(globe.matrixWorld);
    const distToCenter = pos.clone().sub(camera.position).length();
    const distCenterToCamera = globeCenter.clone().sub(camera.position).length();
    const visible = dot > 0 && distToCenter < distCenterToCamera + 0.3;

    return { x, y, visible };
  }

  function updateMarkers() {
    journeyData.forEach((data) => {
      const { x, y, visible } = projectToScreen(data.lat, data.lon);
      const el = data.element;

      if (visible && x > -20 && x < width() + 20 && y > -20 && y < height() + 20) {
        el.style.left = `${x}px`;
        el.style.top = `${y}px`;
        el.style.opacity = "1";
      } else {
        el.style.opacity = "0";
      }
    });
  }

  // ─── Click to Fly ───
  const panel = document.getElementById("country-panel")!;
  const panelImg = panel.querySelector("#panel-image img") as HTMLImageElement;
  const panelStep = document.getElementById("panel-step")!;
  const panelName = document.getElementById("panel-name")!;
  const panelCity = document.getElementById("panel-city")!;
  const panelPeriod = document.getElementById("panel-period")!;

  let isAnimating = false;

  function flyToCountry(data: (typeof journeyData)[0]) {
    if (isAnimating) return;
    isAnimating = true;

    // Hide panel
    panel.style.opacity = "0";
    panel.style.transform = "translateY(1rem)";
    panel.classList.remove("pointer-events-none");

    const targetPos = latLonToVec3(data.lat, data.lon, 1.0);

    const targetRotationY = -((data.lon + 180) * Math.PI) / 180 + Math.PI;
    const targetRotationX = (data.lat * Math.PI) / 180 * 0.3;

    gsap.to(globe.rotation, {
      y: targetRotationY,
      x: targetRotationX,
      duration: 1.8,
      ease: "power3.inOut",
      onUpdate: updateMarkers,
      onComplete: () => {
        isAnimating = false;

        panelImg.src = data.image;
        panelImg.alt = data.name;
        panelStep.textContent = `Step ${data.id} of 8`;
        panelName.textContent = `${data.name}`;
        panelCity.textContent = `${data.city}`;
        panelPeriod.textContent = data.period;

        panel.style.opacity = "1";
        panel.style.transform = "translateY(0)";
      },
    });
  }

  journeyData.forEach((data) => {
    data.element.addEventListener("click", () => flyToCountry(data));
  });

  // ─── Auto-rotate ───
  let autoRotate = true;
  let userInteracting = false;

  controls.addEventListener("start", () => {
    userInteracting = true;
    autoRotate = false;
    // Resume auto-rotate after 5s of no interaction
    clearTimeout((window as any).__globeTimeout);
  });

  controls.addEventListener("end", () => {
    userInteracting = false;
    (window as any).__globeTimeout = setTimeout(() => {
      autoRotate = true;
    }, 5000);
  });

  // ─── Initial Rotation (Show Netherlands) ───
  const nlLon = 5.49;
  globe.rotation.y = -(((nlLon + 180) * Math.PI) / 180) + Math.PI;

  // ─── Animation Loop ───
  function animate() {
    requestAnimationFrame(animate);

    if (autoRotate && !isAnimating) {
      globe.rotation.y += 0.001;
    }

    controls.update();
    updateMarkers();
    renderer.render(scene, camera);
  }

  animate();

  // ─── Resize ───
  const resizeObserver = new ResizeObserver(() => {
    camera.aspect = width() / height();
    camera.updateProjectionMatrix();
    renderer.setSize(width(), height());
  });
  resizeObserver.observe(container);

  // ─── Update Sun Direction Periodically ───
  setInterval(() => {
    earthMaterial.uniforms.sunDirection.value = getSunDirection();
  }, 60000);
</script>
