---
import { about } from "../data/resume";
import WorldMap from "./WorldMap.astro";
---

<section id="about" class="py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-serif font-bold text-slate-900 dark:text-slate-50"
      >
        About Me
      </h2>
      <div class="section-line"></div>
    </div>

    <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-start">
      <!-- Photo -->
      <div class="md:col-span-4 fade-up flex justify-center md:justify-start">
        <div class="relative group">
          <div
            class="w-48 h-60 sm:w-56 sm:h-72 md:w-full md:h-auto md:aspect-[3/4] rounded-3xl overflow-hidden border-2 border-slate-200/50 dark:border-slate-700/50 shadow-2xl shadow-slate-900/10 dark:shadow-black/30 transition-all duration-500 group-hover:border-amber-500/30 dark:group-hover:border-amber-400/30"
          >
            <img
              src="/images/hakan-sahin.png"
              alt="Hakan Sahin"
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <!-- Decorative accent -->
          <div
            class="absolute -bottom-3 -right-3 w-24 h-24 border-2 border-amber-500/15 dark:border-amber-400/15 rounded-3xl -z-10"
          >
          </div>
          <div
            class="absolute -top-3 -left-3 w-16 h-16 border-2 border-slate-200/20 dark:border-slate-700/20 rounded-2xl -z-10"
          >
          </div>
        </div>
      </div>

      <!-- Description + Highlights -->
      <div class="md:col-span-8">
        <div class="fade-up mb-10">
          <p
            class="text-base sm:text-lg md:text-xl leading-relaxed text-slate-600 dark:text-slate-300 font-light"
          >
            {about.description}
          </p>
        </div>

        <!-- Highlights -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 stagger">
          {
            about.highlights.map((item) => (
              <div class="p-5 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 text-center hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300">
                <span class="block text-3xl sm:text-4xl font-serif font-bold text-amber-500 dark:text-amber-400 mb-1">
                  {item.value}
                </span>
                <span class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 tracking-wide">
                  {item.label}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- World Map -->
    <div class="mt-16 md:mt-20 fade-up">
      <p
        class="text-xs font-medium tracking-[0.2em] uppercase text-amber-500 dark:text-amber-400 text-center mb-6"
      >
        Global Journey — 8 Countries, 4 Continents
      </p>
      <WorldMap />
    </div>
  </div>
</section>
