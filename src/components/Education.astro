---
import { education, certifications } from "../data/resume";
---

<section id="education" class="py-24 md:py-32 bg-white/50 dark:bg-slate-900/30">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-bold text-slate-900 dark:text-slate-50">
        Education
      </h2>
      <div class="section-line"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mb-16 stagger">
      {
        education.map((edu) => (
          <div class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-amber-500/10 dark:bg-amber-400/10 flex items-center justify-center shrink-0">
                <svg
                  class="w-6 h-6 text-amber-500 dark:text-amber-400"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
                  />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">
                  {edu.degree}
                </h3>
                <p class="text-amber-600 dark:text-amber-400 font-medium text-sm">{edu.field}</p>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{edu.institution}</p>
                <p class="text-xs text-slate-400 dark:text-slate-500 flex items-center gap-1 mt-1">
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                    />
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                    />
                  </svg>
                  {edu.location}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Certifications -->
    <div class="fade-up">
      <h3
        class="text-sm font-medium tracking-[0.15em] uppercase text-slate-400 dark:text-slate-500 mb-6 text-center"
      >
        Certifications
      </h3>
      <div class="flex flex-wrap justify-center gap-3">
        {
          certifications.map((cert) => (
            <span class="px-4 py-2 text-sm font-medium rounded-full bg-white dark:bg-slate-900/60 border border-slate-200 dark:border-slate-800/60 text-slate-600 dark:text-slate-300 hover:border-amber-500/40 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-300">
              {cert}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
