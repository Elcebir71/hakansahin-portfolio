---
const phrases = [
  "Software Developer",
  "Global Perspective",
  "Modern Web",
  "Clean Code",
  ".NET & Blazor",
  "Problem Solver",
  "Data Science",
  "8 Countries",
];

const separator = " \u2022 ";
const repeated = [...phrases, ...phrases];
---

<div
  class="overflow-hidden py-6 sm:py-8 border-y border-slate-200/40 dark:border-slate-800/40 bg-white/30 dark:bg-slate-900/20"
>
  <div class="marquee-track flex whitespace-nowrap">
    {
      repeated.map((phrase, i) => (
        <span class="inline-flex items-center text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-serif font-bold text-slate-100 dark:text-slate-800/40 select-none shrink-0">
          {phrase}
          <span class="mx-6 sm:mx-8 text-amber-500/20 dark:text-amber-400/15 text-2xl">
            &bull;
          </span>
        </span>
      ))
    }
  </div>
</div>
