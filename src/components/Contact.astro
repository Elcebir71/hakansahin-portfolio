---
import { personalInfo } from "../data/resume";
---

<section id="contact" class="py-24 md:py-32 bg-white/50 dark:bg-slate-900/30">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-bold text-slate-900 dark:text-slate-50">
        Get in Touch
      </h2>
      <div class="section-line"></div>
      <p class="mt-6 text-slate-500 dark:text-slate-400 max-w-lg mx-auto leading-relaxed font-light">
        I'm always open to discussing new opportunities, interesting projects, or ways to collaborate.
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <div class="grid sm:grid-cols-3 gap-6 stagger">
        <a
          href={`mailto:${personalInfo.email}`}
          class="group p-6 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300 text-center"
        >
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-xl bg-amber-500/10 dark:bg-amber-400/10 flex items-center justify-center group-hover:bg-amber-500/20 transition-colors"
          >
            <svg
              class="w-5 h-5 text-amber-500 dark:text-amber-400"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
          </div>
          <p class="text-xs font-medium tracking-[0.1em] uppercase text-slate-400 dark:text-slate-500 mb-1">
            Email
          </p>
          <p
            class="text-sm text-slate-600 dark:text-slate-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors break-all"
          >
            {personalInfo.email}
          </p>
        </a>

        <a
          href={personalInfo.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="group p-6 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300 text-center"
        >
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-xl bg-amber-500/10 dark:bg-amber-400/10 flex items-center justify-center group-hover:bg-amber-500/20 transition-colors"
          >
            <svg class="w-5 h-5 text-amber-500 dark:text-amber-400" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </div>
          <p class="text-xs font-medium tracking-[0.1em] uppercase text-slate-400 dark:text-slate-500 mb-1">
            LinkedIn
          </p>
          <p
            class="text-sm text-slate-600 dark:text-slate-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors"
          >
            Connect with me
          </p>
        </a>

        <a
          href={`tel:${personalInfo.phone.replace(/\s/g, "")}`}
          class="group p-6 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300 text-center"
        >
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-xl bg-amber-500/10 dark:bg-amber-400/10 flex items-center justify-center group-hover:bg-amber-500/20 transition-colors"
          >
            <svg
              class="w-5 h-5 text-amber-500 dark:text-amber-400"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
              ></path>
            </svg>
          </div>
          <p class="text-xs font-medium tracking-[0.1em] uppercase text-slate-400 dark:text-slate-500 mb-1">
            Phone
          </p>
          <p
            class="text-sm text-slate-600 dark:text-slate-300 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors"
          >
            {personalInfo.phone}
          </p>
        </a>
      </div>
    </div>
  </div>
</section>
