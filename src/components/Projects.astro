---
import { projects } from "../data/resume";
---

<section id="projects" class="projects-horizontal">
  <div class="projects-track flex items-center min-h-screen">
    <!-- Section heading as first "card" -->
    <div
      class="shrink-0 w-screen md:w-[45vw] h-screen flex flex-col justify-center px-8 sm:px-12 md:px-20"
    >
      <p
        class="text-xs font-medium tracking-[0.2em] uppercase text-amber-500 dark:text-amber-400 mb-4"
      >
        Selected Work
      </p>
      <h2
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-serif font-bold text-slate-900 dark:text-slate-50 leading-[1.05]"
      >
        Projects
      </h2>
      <div class="section-line !mx-0 !mt-6 !mb-8"></div>
      <p
        class="text-sm sm:text-base text-slate-500 dark:text-slate-400 max-w-sm leading-relaxed font-light"
      >
        Scroll horizontally to explore my work — from enterprise applications to
        machine learning research.
      </p>
      <div
        class="mt-8 flex items-center gap-3 text-xs text-slate-400 dark:text-slate-500 tracking-widest uppercase"
      >
        <span>Scroll</span>
        <svg
          class="w-12 h-px"
          viewBox="0 0 48 1"
          fill="none"
          stroke="currentColor"
          stroke-width="0.5"
        >
          <line x1="0" y1="0.5" x2="48" y2="0.5"></line>
        </svg>
      </div>
    </div>

    <!-- Project cards -->
    {
      projects.map((project, i) => (
        <div class="shrink-0 w-[85vw] sm:w-[70vw] md:w-[55vw] lg:w-[45vw] h-[75vh] mr-8 last:mr-[10vw]">
          <div class="group h-full rounded-3xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-500 flex flex-col relative overflow-hidden">
            <!-- Project image -->
            <div class="relative h-[45%] overflow-hidden">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-white/80 via-transparent to-transparent dark:from-slate-900/80 dark:via-transparent dark:to-transparent" />
              <div class="absolute top-4 right-6 text-[5rem] sm:text-[6rem] font-serif font-bold text-white/10 dark:text-white/5 leading-none select-none pointer-events-none">
                {String(i + 1).padStart(2, "0")}
              </div>
            </div>

            <!-- Project content -->
            <div class="flex-1 p-6 sm:p-8 md:p-10 flex flex-col justify-between relative z-10">
              <div>
                <div class="flex items-start justify-between mb-4">
                  <h3 class="text-xl sm:text-2xl md:text-3xl font-serif font-bold text-slate-900 dark:text-slate-50 leading-tight pr-4">
                    {project.title}
                  </h3>
                  {project.link && (
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-slate-400 hover:text-amber-500 dark:hover:text-amber-400 transition-colors shrink-0 mt-1"
                      aria-label={`View ${project.title}`}
                      data-magnetic
                    >
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                        />
                      </svg>
                    </a>
                  )}
                </div>

                <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 leading-relaxed font-light">
                  {project.description}
                </p>
              </div>

              <div class="flex flex-wrap gap-2 mt-6">
                {project.tags.map((tag) => (
                  <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-amber-500/10 dark:bg-amber-400/10 text-amber-600 dark:text-amber-400">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
