---
import { personalInfo } from "../data/resume";
const nameWords = personalInfo.name.split(" ");
---

<section
  id="hero"
  class="min-h-screen flex items-center justify-center relative overflow-hidden"
>
  <!-- Parallax background layers -->
  <div class="absolute inset-0 pointer-events-none" data-speed="-0.5">
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_20%,rgba(251,191,36,0.06),transparent_60%)] dark:bg-[radial-gradient(ellipse_at_30%_20%,rgba(251,191,36,0.08),transparent_60%)]"
    >
    </div>
  </div>

  <!-- Floating decorative elements -->
  <div
    class="absolute top-[20%] left-[8%] w-28 h-28 border border-amber-500/[0.07] dark:border-amber-400/[0.07] rounded-full"
    data-speed="-2"
  >
  </div>
  <div
    class="absolute bottom-[30%] right-[12%] w-20 h-20 border border-slate-300/10 dark:border-slate-600/10 rotate-45"
    data-speed="1.5"
  >
  </div>
  <div
    class="absolute top-[35%] right-[22%] w-2 h-2 bg-amber-500/20 rounded-full"
    data-speed="-1"
  >
  </div>
  <div
    class="absolute bottom-[45%] left-[20%] w-1.5 h-1.5 bg-slate-400/15 dark:bg-slate-500/15 rounded-full"
    data-speed="2"
  >
  </div>

  <div class="relative text-center px-6 max-w-6xl mx-auto">
    <!-- Title label -->
    <p
      class="hero-label text-amber-500 dark:text-amber-400 font-medium tracking-[0.3em] uppercase text-xs sm:text-sm mb-8 opacity-0 translate-y-4"
    >
      {personalInfo.title}
    </p>

    <!-- Kinetic Typography -->
    <h1 class="hero-title mb-10">
      {
        nameWords.map((word, wordIndex) => (
          <span class="block leading-[0.9] mb-2">
            {word.split("").map((char) => (
              <span class="char-wrap">
                <span class="hero-char font-serif font-bold text-[16vw] sm:text-[14vw] md:text-[12vw] lg:text-[10vw] text-slate-900 dark:text-slate-50">
                  {char}
                </span>
              </span>
            ))}
          </span>
        ))
      }
    </h1>

    <!-- Tagline -->
    <p
      class="hero-tagline text-base sm:text-lg md:text-xl text-slate-500 dark:text-slate-400 max-w-2xl mx-auto mb-4 leading-relaxed font-light opacity-0 translate-y-4"
    >
      {personalInfo.tagline}
    </p>

    <!-- Location -->
    <p
      class="hero-location text-sm text-slate-400 dark:text-slate-500 mb-14 flex items-center justify-center gap-2 opacity-0 translate-y-4"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
        ></path>
      </svg>
      {personalInfo.location}
    </p>

    <!-- CTAs -->
    <div
      class="hero-cta flex flex-col sm:flex-row gap-4 justify-center opacity-0 translate-y-4"
    >
      <a
        href="#contact"
        data-magnetic
        class="inline-flex items-center justify-center px-8 py-3.5 bg-amber-500 hover:bg-amber-600 text-white font-medium text-sm rounded-full transition-all duration-300 hover:shadow-lg hover:shadow-amber-500/20 tracking-wide"
      >
        Get in Touch
      </a>
      <a
        href="#experience"
        data-magnetic
        class="inline-flex items-center justify-center px-8 py-3.5 border border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:border-amber-500 dark:hover:border-amber-400 hover:text-amber-600 dark:hover:text-amber-400 font-medium text-sm rounded-full transition-all duration-300 tracking-wide"
      >
        View Experience
      </a>
    </div>

    <!-- Social links -->
    <div class="hero-social mt-16 flex justify-center gap-6 opacity-0">
      <a
        href={`mailto:${personalInfo.email}`}
        class="text-slate-400 hover:text-amber-500 dark:hover:text-amber-400 transition-colors duration-300"
        aria-label="Email"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
          ></path>
        </svg>
      </a>
      <a
        href={personalInfo.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-400 hover:text-amber-500 dark:hover:text-amber-400 transition-colors duration-300"
        aria-label="LinkedIn"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="hero-scroll absolute bottom-10 left-1/2 -translate-x-1/2 opacity-0"
  >
    <div
      class="w-5 h-9 border-2 border-slate-300 dark:border-slate-600 rounded-full flex justify-center pt-1.5"
    >
      <div
        class="scroll-indicator-dot w-1 h-2 bg-amber-500 rounded-full"
      >
      </div>
    </div>
  </div>
</section>
