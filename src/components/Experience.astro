---
import { experiences } from "../data/resume";

const featured = experiences.filter((e) => e.type === "featured");
const compact = experiences.filter((e) => e.type === "compact");
---

<section id="experience" class="py-24 md:py-32 bg-white/50 dark:bg-slate-900/30">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 fade-up">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-serif font-bold text-slate-900 dark:text-slate-50">
        Experience
      </h2>
      <div class="section-line"></div>
    </div>

    <!-- Featured roles -->
    <div class="space-y-8 mb-16">
      {
        featured.map((exp, i) => (
          <div class="fade-up group">
            <div class="p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300 hover:shadow-lg hover:shadow-slate-200/50 dark:hover:shadow-slate-900/50">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-slate-50">
                    {exp.title}
                  </h3>
                  <p class="text-amber-600 dark:text-amber-400 font-medium text-sm">
                    {exp.company}
                  </p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-sm text-slate-500 dark:text-slate-400">{exp.period}</p>
                  <p class="text-xs text-slate-400 dark:text-slate-500 flex items-center gap-1 sm:justify-end">
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                      />
                    </svg>
                    {exp.location}
                  </p>
                </div>
              </div>

              {exp.description && (
                <p class="text-slate-600 dark:text-slate-300 text-sm mb-4 leading-relaxed font-light">
                  {exp.description}
                </p>
              )}

              {exp.highlights && exp.highlights.length > 0 && (
                <ul class="space-y-2">
                  {exp.highlights.map((h) => (
                    <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-400">
                      <span class="w-1 h-1 rounded-full bg-amber-500 mt-2 shrink-0" />
                      {h}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Compact timeline for earlier roles -->
    <div class="fade-up">
      <h3
        class="text-sm font-medium tracking-[0.15em] uppercase text-slate-400 dark:text-slate-500 mb-8 text-center"
      >
        Earlier Career
      </h3>

      <div class="relative">
        <div
          class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-px bg-slate-200 dark:bg-slate-800"
        >
        </div>

        <div class="space-y-6 stagger">
          {
            compact.map((exp, i) => (
              <div
                class={`relative flex items-center gap-6 ${i % 2 === 0 ? "sm:flex-row" : "sm:flex-row-reverse"}`}
              >
                <div class={`flex-1 hidden sm:block ${i % 2 === 0 ? "text-right" : "text-left"}`}>
                  <p class="text-sm font-medium text-slate-700 dark:text-slate-300">{exp.title}</p>
                  <p class="text-xs text-amber-600 dark:text-amber-400">{exp.company}</p>
                </div>

                <div class="absolute left-4 sm:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-amber-500/80 border-2 border-white dark:border-slate-950 z-10" />

                <div class={`flex-1 pl-10 sm:pl-0 ${i % 2 === 0 ? "sm:text-left" : "sm:text-right"}`}>
                  <p class="text-sm font-medium text-slate-700 dark:text-slate-300 sm:hidden">
                    {exp.title}
                  </p>
                  <p class="text-xs text-amber-600 dark:text-amber-400 sm:hidden">{exp.company}</p>
                  <p class="text-xs text-slate-400 dark:text-slate-500">{exp.period}</p>
                  <p class="text-xs text-slate-400 dark:text-slate-500">{exp.location}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
