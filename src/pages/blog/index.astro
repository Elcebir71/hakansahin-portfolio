---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const posts = [
  {
    title: "My Journey into Software Development",
    description:
      "From mathematics education across the globe to building modern web applications with .NET and Blazor — how a career pivot led to discovering a new passion.",
    date: "2026-02-23",
    tags: ["career", "development"],
    slug: "#",
  },
];
---

<Layout title="Blog — Hakan Sahin">
  <Header />
  <main class="pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 fade-up">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif font-bold text-slate-900 dark:text-slate-50">
          Blog
        </h1>
        <div class="section-line"></div>
        <p class="mt-6 text-slate-500 dark:text-slate-400 max-w-lg mx-auto leading-relaxed font-light">
          Thoughts on software development, technology, and career growth.
        </p>
      </div>

      <div class="space-y-6 stagger">
        {
          posts.map((post) => (
            <article class="group p-6 sm:p-8 rounded-2xl bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/60 hover:border-amber-500/30 dark:hover:border-amber-400/30 transition-all duration-300">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <h2 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-slate-50 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
                  {post.title}
                </h2>
                <time class="text-sm text-slate-400 dark:text-slate-500 shrink-0">{post.date}</time>
              </div>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-light mb-4">
                {post.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {post.tags.map((tag) => (
                  <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-amber-500/10 dark:bg-amber-400/10 text-amber-600 dark:text-amber-400">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>

      <div class="text-center mt-16 fade-up">
        <p class="text-sm text-slate-400 dark:text-slate-500 italic">
          More posts coming soon...
        </p>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
